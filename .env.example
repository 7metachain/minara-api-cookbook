# ============================================================
# Minara API Cookbook — Environment Variables
# ============================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# ============================================================

# --- API Key Authentication (for examples 01, 03, 04, 05) ---
# Get your key: https://minara.ai → Profile → API tab (Pro/Partner plan required)
MINARA_API_KEY=your_api_key_here

# --- x402 Authentication (for example 02) ---
# Your EVM wallet private key (with USDC balance on Base chain)
# ⚠️ NEVER commit this value. Use a dedicated dev wallet with small balances.
EVM_PRIVATE_KEY=0xyour_private_key_here
